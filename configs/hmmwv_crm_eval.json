{
  "dataset_name": "hmmwv_crm_eval",
  "chrono_data_root": "chrono/data",
  "vehicle_data_root": "chrono/data/vehicle",
  "output_subdir": "artifacts/datasets/hmmwv_crm_eval",
  "simulation": {
    "step_size_s": 0.0005,
    "tire_step_size_s": 0.0005,
    "record_step_s": 0.01,
    "driver_sample_step_s": 0.01,
    "validation_ratio": 0.0,
    "chrono_threads": 12,
    "collision_threads": 1,
    "eigen_threads": 1
  },
  "vehicle": {
    "model": "HMMWV_Full",
    "contact_method": "SMC",
    "chassis_fixed": false,
    "init": {
      "x_m": 0.0,
      "y_m": 0.0,
      "z_m": 0.7
    },
    "engine_model": "SHAFTS",
    "transmission_model": "AUTOMATIC_SHAFTS",
    "drive_type": "AWD",
    "steering_type": "PITMAN_ARM",
    "tire_model": "RIGID_MESH"
  },
  "terrain": {
    "type": "crm",
    "length_m": 150.0,
    "width_m": 150.0,
    "depth_m": 0.25,
    "center_m": [0.0, 0.0, 0.0],
    "boundary_margin_m": 5.0,
    "initial_spacing_m": 0.08,
    "active_domain_m": [2.0, 2.0, 1.0],
    "active_domain_delay_s": 0.1,
    "soil": {
      "density": 1700.0,
      "cohesion": 5000.0,
      "friction": 0.8,
      "young_modulus_pa": 1000000.0,
      "poisson_ratio": 0.3,
      "mu_I0": 0.04,
      "average_diam_m": 0.005
    },
    "sph": {
      "integration_scheme": "RK2",
      "d0_multiplier": 1.0,
      "free_surface_threshold": 2.0,
      "artificial_viscosity": 0.5,
      "shifting_method": "NONE",
      "shifting_ppst_push": 1.0,
      "shifting_ppst_pull": 1.0,
      "viscosity_method": "ARTIFICIAL_BILATERAL",
      "boundary_method": "ADAMI",
      "num_proximity_search_steps": 4
    }
  },
  "logging": {
    "include_tire_channels": true,
    "tire_force_source": "crm_fsi"
  }
}
